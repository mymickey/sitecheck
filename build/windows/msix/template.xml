<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="sitecheck"
        Arguments=""
        InstallLocation="C:\Program Files\SiteCheck\SiteCheck">
    </Installer>
    <PackageInformation
        PackageName="SiteCheck"
        PackageDisplayName="SiteCheck"
        PublisherName="CN=SiteCheck"
        PublisherDisplayName="SiteCheck"
        Version="0.1.0.0"
        PackageDescription="Menubar network connectivity monitor">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="app.sitecheck.menubar"
                Description="Menubar network connectivity monitor"
                DisplayName="SiteCheck"
                ExecutableName="sitecheck"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>SiteCheck</DisplayName>
            <PublisherDisplayName>SiteCheck</PublisherDisplayName>
            <Description>Menubar network connectivity monitor</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="sitecheck.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
